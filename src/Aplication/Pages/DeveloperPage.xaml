<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Aplication.Pages.DeveloperPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Tryb deweloperski"
    BackgroundColor="{StaticResource Paper200}">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="RustButtonBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Offset="0.0" Color="{StaticResource Rust500}" />
            <GradientStop Offset="1.0" Color="{StaticResource Rust600}" />
        </LinearGradientBrush>

        <!-- Wszystkie przyciski panelu w rdzawym stylu marki (analogicznie do trybu planowania). -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource RustButtonBrush}" />
            <Setter Property="TextColor" Value="{StaticResource Paper50}" />
            <Setter Property="FontFamily" Value="{StaticResource FontUiSemibold}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,8" />
        </Style>
    </ContentPage.Resources>

    <Grid x:Name="RootGrid" ColumnDefinitions="*,340">

        <!-- Plansza (MapBoardView, tryb podkładu) jest wstawiana w kodzie do kolumny 0. -->

        <ActivityIndicator
            x:Name="LoadingIndicator"
            Grid.Column="0"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Color="{StaticResource Rust600}"
            IsRunning="True" />

        <!-- Zoom mapy: przybliżanie (+) i oddalanie (−) w prawym dolnym rogu planszy. -->
        <VerticalStackLayout
            Grid.Column="0"
            Margin="16"
            HorizontalOptions="End"
            VerticalOptions="End"
            Spacing="10">

            <Border
                WidthRequest="44"
                HeightRequest="44"
                Padding="0"
                BackgroundColor="{StaticResource Paper50}"
                Stroke="{StaticResource BorderDefault}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Walnut900}" Offset="0,4" Radius="16" Opacity="0.16" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnZoomInTapped" />
                </Border.GestureRecognizers>
                <!-- Lupka z „+" -->
                <Path
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    HeightRequest="20"
                    WidthRequest="20"
                    Aspect="Uniform"
                    Data="M9,2 A7,7 0 1 0 9,16 A7,7 0 1 0 9,2 M14,14 L20,20 M9,5.5 L9,12.5 M5.5,9 L12.5,9"
                    Stroke="{StaticResource Sepia600}"
                    StrokeThickness="2"
                    StrokeLineCap="Round" />
            </Border>

            <Border
                WidthRequest="44"
                HeightRequest="44"
                Padding="0"
                BackgroundColor="{StaticResource Paper50}"
                Stroke="{StaticResource BorderDefault}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Walnut900}" Offset="0,4" Radius="16" Opacity="0.16" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnZoomOutTapped" />
                </Border.GestureRecognizers>
                <!-- Lupka z „−" -->
                <Path
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    HeightRequest="20"
                    WidthRequest="20"
                    Aspect="Uniform"
                    Data="M9,2 A7,7 0 1 0 9,16 A7,7 0 1 0 9,2 M14,14 L20,20 M5.5,9 L12.5,9"
                    Stroke="{StaticResource Sepia600}"
                    StrokeThickness="2"
                    StrokeLineCap="Round" />
            </Border>

        </VerticalStackLayout>

        <ScrollView Grid.Column="1" BackgroundColor="{StaticResource Paper100}">
            <VerticalStackLayout Padding="14" Spacing="12">

                <!-- Przełącznik karty: miasta / trasy -->
                <HorizontalStackLayout Spacing="8">
                    <Button
                        Text="Miasta"
                        Command="{Binding SelectCitiesTabCommand}" />
                    <Button
                        Text="Trasy"
                        Command="{Binding SelectRoutesTabCommand}" />
                </HorizontalStackLayout>

                <BoxView HeightRequest="1" Color="{StaticResource BorderDefault}" />

                <!-- Eksport danych roboczych do schowka (JSON zgodny z mapa.json) -->
                <Button
                    Text="Kopiuj dane do schowka (JSON)"
                    Command="{Binding ExportToClipboardCommand}" />
                <Label
                    FontSize="12"
                    TextColor="{StaticResource Success600}"
                    Text="{Binding ExportStatusMessage}" />

                <BoxView HeightRequest="1" Color="{StaticResource BorderDefault}" />

                <VerticalStackLayout Spacing="12" IsVisible="{Binding IsCitiesTab}">

                    <Label
                        FontSize="16"
                        FontAttributes="Bold"
                        Text="Miasta" />
                    <Label
                        FontSize="12"
                        TextColor="{StaticResource Sepia600}"
                        Text="Dotknij mapy, aby wskazać położenie, wybierz nazwę z listy i dodaj miasto." />

                    <!-- Formularz dodawania / edycji miasta -->
                    <Entry
                        Placeholder="Nazwa miasta"
                        Text="{Binding CityName}" />

                    <CollectionView
                        ItemsSource="{Binding NameSuggestions}"
                        IsVisible="{Binding HasSuggestions}"
                        SelectionMode="Single"
                        SelectionChanged="OnNameSuggestionSelected"
                        BackgroundColor="{StaticResource Paper50}"
                        MaximumHeightRequest="180">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Padding="10,8" Text="{Binding .}" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="{Binding PickedPositionText}" />

                    <HorizontalStackLayout Spacing="8">
                        <Button
                            Text="{Binding SubmitLabel}"
                            Command="{Binding AddOrUpdateCityCommand}" />
                        <Button
                            Text="Anuluj"
                            IsVisible="{Binding IsEditing}"
                            Command="{Binding CancelEditCommand}" />
                    </HorizontalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource BorderDefault}" />

                    <!-- Lista roboczych miast -->
                    <Label
                        FontAttributes="Bold"
                        Text="Lista miast" />

                    <CollectionView ItemsSource="{Binding Cities}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,4" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                    <VerticalStackLayout Grid.Column="0">
                                        <Label FontAttributes="Bold" Text="{Binding Name}" />
                                        <Label FontSize="11" TextColor="{StaticResource Sepia600}">
                                            <Label.Text>
                                                <MultiBinding StringFormat="{}{0:0}, {1:0}">
                                                    <Binding Path="X" />
                                                    <Binding Path="Y" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                    </VerticalStackLayout>
                                    <Button
                                        Grid.Column="1"
                                        Text="Edytuj"
                                        FontSize="11"
                                        Padding="8,2"
                                        Command="{Binding Path=BindingContext.EditCityCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                        CommandParameter="{Binding .}" />
                                    <Button
                                        Grid.Column="2"
                                        Text="Usuń"
                                        FontSize="11"
                                        Padding="8,2"
                                        Command="{Binding Path=BindingContext.DeleteCityCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                        CommandParameter="{Binding .}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>

                <VerticalStackLayout Spacing="12" IsVisible="{Binding IsRoutesTab}">

                    <Label
                        FontSize="16"
                        FontAttributes="Bold"
                        Text="Trasy" />
                    <Label
                        FontSize="12"
                        TextColor="{StaticResource Sepia600}"
                        Text="Wybierz miasto początkowe i końcowe, a następnie dotknij mapy dwukrotnie (dwa rogi przekątnej), aby dodać kolejny wagonik." />

                    <!-- Formularz dodawania / edycji trasy -->
                    <Entry
                        Placeholder="Miasto początkowe"
                        Text="{Binding RouteCityFromText}" />
                    <CollectionView
                        ItemsSource="{Binding RouteCityFromSuggestions}"
                        IsVisible="{Binding HasRouteCityFromSuggestions}"
                        SelectionMode="Single"
                        SelectionChanged="OnRouteCityFromSuggestionSelected"
                        BackgroundColor="{StaticResource Paper50}"
                        MaximumHeightRequest="140">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Padding="10,8" Text="{Binding .}" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Entry
                        Placeholder="Miasto końcowe"
                        Text="{Binding RouteCityToText}" />
                    <CollectionView
                        ItemsSource="{Binding RouteCityToSuggestions}"
                        IsVisible="{Binding HasRouteCityToSuggestions}"
                        SelectionMode="Single"
                        SelectionChanged="OnRouteCityToSuggestionSelected"
                        BackgroundColor="{StaticResource Paper50}"
                        MaximumHeightRequest="140">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Padding="10,8" Text="{Binding .}" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="{Binding WagonPickHint}" />
                    <Label Text="{Binding PendingWagons.Count, StringFormat='Wagoniki: {0}'}" />

                    <CollectionView ItemsSource="{Binding PendingWagons}" MaximumHeightRequest="140">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,4" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                    <Label Grid.Column="0" FontSize="11" TextColor="{StaticResource Sepia600}">
                                        <Label.Text>
                                            <MultiBinding StringFormat="({0:0}, {1:0}) - ({2:0}, {3:0})">
                                                <Binding Path="A.X" />
                                                <Binding Path="A.Y" />
                                                <Binding Path="B.X" />
                                                <Binding Path="B.Y" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                    <Button
                                        Grid.Column="1"
                                        Text="Edytuj"
                                        FontSize="11"
                                        Padding="8,2"
                                        Command="{Binding Path=BindingContext.EditWagonCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                        CommandParameter="{Binding .}" />
                                    <Button
                                        Grid.Column="2"
                                        Text="Usuń"
                                        FontSize="11"
                                        Padding="8,2"
                                        Command="{Binding Path=BindingContext.RemoveWagonCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                        CommandParameter="{Binding .}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <HorizontalStackLayout Spacing="8">
                        <Button
                            Text="{Binding RouteSubmitLabel}"
                            Command="{Binding SaveRouteCommand}" />
                        <Button
                            Text="Anuluj"
                            IsVisible="{Binding IsEditingRoute}"
                            Command="{Binding CancelRouteEditCommand}" />
                    </HorizontalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource BorderDefault}" />

                    <!-- Lista roboczych tras -->
                    <Label
                        FontAttributes="Bold"
                        Text="Lista tras" />

                    <CollectionView ItemsSource="{Binding Routes}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,4" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                    <VerticalStackLayout Grid.Column="0">
                                        <Label FontAttributes="Bold">
                                            <Label.Text>
                                                <MultiBinding StringFormat="{}{0} - {1}">
                                                    <Binding Path="CityFromName" />
                                                    <Binding Path="CityToName" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                        <Label FontSize="11" TextColor="{StaticResource Sepia600}" Text="{Binding WagonCount, StringFormat='Wagoniki: {0}'}" />
                                    </VerticalStackLayout>
                                    <Button
                                        Grid.Column="1"
                                        Text="Edytuj"
                                        FontSize="11"
                                        Padding="8,2"
                                        Command="{Binding Path=BindingContext.EditRouteCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                        CommandParameter="{Binding .}" />
                                    <Button
                                        Grid.Column="2"
                                        Text="Usuń"
                                        FontSize="11"
                                        Padding="8,2"
                                        Command="{Binding Path=BindingContext.DeleteRouteCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                        CommandParameter="{Binding .}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
