<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Aplication.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Wsiąść do pociągu">

    <Grid x:Name="RootLayout">

        <!-- Plansza (MapBoardView) jest wstawiana w kodzie po wczytaniu danych. -->

        <ActivityIndicator
            x:Name="LoadingIndicator"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            IsRunning="True" />

        <!-- Krótka legenda PoC: jak działa interakcja. -->
        <Border
            Margin="12"
            Padding="10,6"
            HorizontalOptions="Start"
            VerticalOptions="Start"
            BackgroundColor="#CC000000"
            StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>
            <Label
                FontSize="11"
                TextColor="White"
                Text="Tap miasta = oznacz/odznacz • Tap trasy = brak→zaznaczona→wykonana • Pinch = zoom • Pan = przesuń" />
        </Border>

    </Grid>

</ContentPage>
