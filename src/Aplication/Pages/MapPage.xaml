<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Aplication.Pages.MapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:Aplication.Models"
    Shell.NavBarIsVisible="False"
    Title="Mapa">

    <Grid x:Name="RootLayout">

        <!-- Plansza (MapBoardView) jest wstawiana w kodzie po wczytaniu danych i wypełnia cały ekran. -->

        <ActivityIndicator
            x:Name="LoadingIndicator"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            IsRunning="True" />

        <!-- Wyszukiwanie miasta — stan zwinięty: sama lupka; kliknięcie rozwija pole tekstowe. -->
        <Border
            x:Name="CollapsedSearchButton"
            Margin="16"
            HorizontalOptions="Start"
            VerticalOptions="Start"
            WidthRequest="52"
            HeightRequest="52"
            Padding="0"
            BackgroundColor="{StaticResource Paper50}"
            Stroke="{StaticResource BorderDefault}"
            StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="26" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="{StaticResource Walnut900}" Offset="0,4" Radius="16" Opacity="0.16" />
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnSearchButtonTapped" />
            </Border.GestureRecognizers>
            <Path
                HorizontalOptions="Center"
                VerticalOptions="Center"
                HeightRequest="24"
                WidthRequest="24"
                Aspect="Uniform"
                Data="M9,2 A7,7 0 1 0 9,16 A7,7 0 1 0 9,2 M14,14 L20,20"
                Stroke="{StaticResource Sepia600}"
                StrokeThickness="2"
                StrokeLineCap="Round" />
        </Border>

        <!-- Wyszukiwanie miasta — stan rozwinięty: pole tekstowe + podpowiedzi (zwykły tekst), wybór = zoom + oznaczenie. -->
        <VerticalStackLayout
            x:Name="SearchExpanded"
            IsVisible="False"
            Margin="16"
            HorizontalOptions="Start"
            VerticalOptions="Start"
            WidthRequest="300"
            Spacing="6">

            <Border
                BackgroundColor="{StaticResource Paper50}"
                Stroke="{StaticResource BorderDefault}"
                StrokeThickness="1"
                Padding="14,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Walnut900}" Offset="0,4" Radius="16" Opacity="0.16" />
                </Border.Shadow>

                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">

                    <!-- Ikona lupy -->
                    <Path
                        Grid.Column="0"
                        VerticalOptions="Center"
                        HeightRequest="18"
                        WidthRequest="18"
                        Aspect="Uniform"
                        Data="M9,2 A7,7 0 1 0 9,16 A7,7 0 1 0 9,2 M14,14 L20,20"
                        Stroke="{StaticResource Sepia600}"
                        StrokeThickness="2"
                        StrokeLineCap="Round" />

                    <Entry
                        x:Name="CitySearchEntry"
                        Grid.Column="1"
                        HeightRequest="48"
                        BackgroundColor="Transparent"
                        FontFamily="{StaticResource FontBody}"
                        FontSize="16"
                        TextColor="{StaticResource Walnut900}"
                        PlaceholderColor="{StaticResource Saddle400}"
                        Placeholder="Szukaj miasta…"
                        TextChanged="OnCitySearchTextChanged"
                        Unfocused="OnCitySearchUnfocused" />

                    <!-- Przycisk czyszczenia pola -->
                    <Border
                        x:Name="ClearSearchButton"
                        Grid.Column="2"
                        IsVisible="False"
                        VerticalOptions="Center"
                        WidthRequest="24"
                        HeightRequest="24"
                        Padding="0"
                        BackgroundColor="{StaticResource Paper300}"
                        StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnClearSearchTapped" />
                        </Border.GestureRecognizers>
                        <Path
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            HeightRequest="10"
                            WidthRequest="10"
                            Aspect="Uniform"
                            Data="M0,0 L10,10 M10,0 L0,10"
                            Stroke="{StaticResource Sepia600}"
                            StrokeThickness="2"
                            StrokeLineCap="Round" />
                    </Border>
                </Grid>
            </Border>

            <!-- Lista podpowiedzi -->
            <Border
                x:Name="CitySearchResultsPanel"
                IsVisible="False"
                BackgroundColor="{StaticResource Paper50}"
                Stroke="{StaticResource BorderDefault}"
                StrokeThickness="1"
                Padding="0,8">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Walnut900}" Offset="0,6" Radius="18" Opacity="0.16" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="0">
                    <Label
                        Margin="16,2,16,6"
                        Text="PODPOWIEDZI"
                        FontFamily="{StaticResource FontUiSemibold}"
                        FontSize="11"
                        CharacterSpacing="1.8"
                        TextColor="{StaticResource Saddle400}" />

                    <CollectionView
                        x:Name="CitySearchResults"
                        SelectionMode="Single"
                        SelectionChanged="OnCitySearchResultSelected"
                        MaximumHeightRequest="220">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:City">
                                <Label
                                    Padding="16,10"
                                    Text="{Binding Name}"
                                    FontFamily="{StaticResource FontBody}"
                                    FontSize="15"
                                    TextColor="{StaticResource Walnut900}" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

        <!-- Liczniki wagonów: zaznaczone / wykonane trasy, jeden pod drugim przy prawej krawędzi. -->
        <VerticalStackLayout
            Margin="16"
            HorizontalOptions="End"
            VerticalOptions="Start"
            WidthRequest="80"
            Spacing="8">

            <Border
                HorizontalOptions="Fill"
                BackgroundColor="{StaticResource Paper50}"
                Stroke="{StaticResource BorderDefault}"
                StrokeThickness="1"
                Padding="8,5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Walnut900}" Offset="0,3" Radius="10" Opacity="0.16" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="1" HorizontalOptions="Center">
                    <Label
                        x:Name="SelectedCountLabel"
                        Text="0"
                        HorizontalOptions="Center"
                        FontFamily="{StaticResource FontDisplayBold}"
                        FontSize="19"
                        TextColor="{StaticResource Walnut900}" />
                    <Label
                        Text="ZAZNACZONE"
                        HorizontalOptions="Center"
                        FontFamily="{StaticResource FontUiSemibold}"
                        FontSize="8"
                        CharacterSpacing="1.0"
                        TextColor="{StaticResource Sepia600}" />
                </VerticalStackLayout>
            </Border>

            <Border
                HorizontalOptions="Fill"
                BackgroundColor="{StaticResource Paper50}"
                Stroke="{StaticResource BorderDefault}"
                StrokeThickness="1"
                Padding="8,5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Walnut900}" Offset="0,3" Radius="10" Opacity="0.16" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="1" HorizontalOptions="Center">
                    <Label
                        x:Name="DoneCountLabel"
                        Text="0"
                        HorizontalOptions="Center"
                        FontFamily="{StaticResource FontDisplayBold}"
                        FontSize="19"
                        TextColor="{StaticResource Rust600}" />
                    <Label
                        Text="WYKONANE"
                        HorizontalOptions="Center"
                        FontFamily="{StaticResource FontUiSemibold}"
                        FontSize="8"
                        CharacterSpacing="1.0"
                        TextColor="{StaticResource Sepia600}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

        <!-- Zoom mapy: przybliżanie (+) i oddalanie (−) w prawym dolnym rogu. -->
        <VerticalStackLayout
            Margin="16"
            HorizontalOptions="End"
            VerticalOptions="End"
            Spacing="10">

            <Border
                WidthRequest="44"
                HeightRequest="44"
                Padding="0"
                BackgroundColor="{StaticResource Paper50}"
                Stroke="{StaticResource BorderDefault}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Walnut900}" Offset="0,4" Radius="16" Opacity="0.16" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnZoomInTapped" />
                </Border.GestureRecognizers>
                <!-- Lupka z „+" -->
                <Path
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    HeightRequest="20"
                    WidthRequest="20"
                    Aspect="Uniform"
                    Data="M9,2 A7,7 0 1 0 9,16 A7,7 0 1 0 9,2 M14,14 L20,20 M9,5.5 L9,12.5 M5.5,9 L12.5,9"
                    Stroke="{StaticResource Sepia600}"
                    StrokeThickness="2"
                    StrokeLineCap="Round" />
            </Border>

            <Border
                WidthRequest="44"
                HeightRequest="44"
                Padding="0"
                BackgroundColor="{StaticResource Paper50}"
                Stroke="{StaticResource BorderDefault}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Walnut900}" Offset="0,4" Radius="16" Opacity="0.16" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnZoomOutTapped" />
                </Border.GestureRecognizers>
                <!-- Lupka z „−" -->
                <Path
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    HeightRequest="20"
                    WidthRequest="20"
                    Aspect="Uniform"
                    Data="M9,2 A7,7 0 1 0 9,16 A7,7 0 1 0 9,2 M14,14 L20,20 M5.5,9 L12.5,9"
                    Stroke="{StaticResource Sepia600}"
                    StrokeThickness="2"
                    StrokeLineCap="Round" />
            </Border>

        </VerticalStackLayout>

    </Grid>

</ContentPage>
