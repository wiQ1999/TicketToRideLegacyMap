<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Aplication.Pages.MapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Mapa">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Ustawienia" Clicked="OnSettingsClicked" />
    </ContentPage.ToolbarItems>

    <Grid x:Name="RootLayout">

        <!-- Plansza (MapBoardView) jest wstawiana w kodzie po wczytaniu danych. -->

        <ActivityIndicator
            x:Name="LoadingIndicator"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            IsRunning="True" />

        <!-- Krótka legenda: interakcja i gesty widoku mapy. -->
        <Border
            Margin="12"
            Padding="10,6"
            HorizontalOptions="Start"
            VerticalOptions="Start"
            BackgroundColor="#CC000000"
            StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>
            <Label
                FontSize="11"
                TextColor="White"
                Text="Tap miasta = oznacz/odznacz • Tap trasy = zaznaczona→wykonana→reset • Pinch = zoom • Pan = przesuń" />
        </Border>

        <!-- Liczniki wagonów: zaznaczone / wykonane trasy. -->
        <Border
            Margin="12"
            Padding="10,6"
            HorizontalOptions="End"
            VerticalOptions="Start"
            BackgroundColor="#CC000000"
            StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>
            <Label
                x:Name="CountersLabel"
                FontSize="11"
                TextColor="White" />
        </Border>

        <!-- Wyszukiwanie miasta: podpowiedzi podczas wpisywania, wybór = zoom + oznaczenie. -->
        <VerticalStackLayout
            Margin="12,56,12,0"
            HorizontalOptions="Center"
            VerticalOptions="Start"
            WidthRequest="280"
            Spacing="4">

            <Entry
                x:Name="CitySearchEntry"
                Placeholder="Szukaj miasta…"
                BackgroundColor="White"
                TextChanged="OnCitySearchTextChanged" />

            <CollectionView
                x:Name="CitySearchResults"
                IsVisible="False"
                BackgroundColor="White"
                SelectionMode="Single"
                SelectionChanged="OnCitySearchResultSelected"
                MaximumHeightRequest="200">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Label Padding="10,8" Text="{Binding Name}" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>

    </Grid>

</ContentPage>
